{% extends 'base.html.twig' %}

{% block title %}Вход / StudyOn{% endblock %}

{% block navbar %}{% endblock %}

{% block body %}
<form method="post">
    {% if error %}
        <div class="d-flex flex-column align-items-center w-100">
            <div class="alert alert-danger d-flex align-items-center w-50 show fade" role="alert">
                <div class="w-100">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    {% endif %}

    <div class="container mt-5 d-flex flex-column align-items-center">
        <div class="d-flex flex-column gap-2 col-5">
            <h1 class="h3 mb-3 font-weight-normal text-center">
                Добро пожаловать в
                <a href="{{ path('app_course_index') }}" class="text-decoration-none">StudyOn!</a>
            </h1>

            <div class="mb-3">
                <label for="inputEmail">Email</label>

                <input
                    type="email"
                    value="{{ last_username }}"
                    name="email" id="inputEmail"
                    class="form-control {{ field_errors.email is defined ? 'is-invalid' : '' }}"
                    autocomplete="email"
                    required
                    autofocus
                    {% if field_errors.email is defined %}
                        aria-describedby="login_email_error"
                        aria-invalid="true"
                    {% endif %}
                >

                {% for message in field_errors.email ?? [] %}
                    <div class="invalid-feedback d-block" id="login_email_error">
                        {{ message }}
                    </div>
                {% endfor %}
            </div>

            <div class="mb-3">
                <label for="inputPassword">Пароль</label>

                <input
                    type="password"
                    name="password"
                    id="inputPassword"
                    class="form-control {{ field_errors.password is defined ? 'is-invalid' : '' }}"
                    autocomplete="current-password"
                    required
                    {% if field_errors.password is defined %}
                        aria-describedby="login_password_error"
                        aria-invalid="true"
                    {% endif %}
                >

                {% for message in field_errors.password ?? [] %}
                    <div class="invalid-feedback d-block" id="login_password_error">
                        {{ message }}
                    </div>
                {% endfor %}
            </div>

            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <div class="checkbox mb-3">
                <label>
                    <input type="checkbox" name="_remember_me"> Запомнить меня
                </label>
            </div>

            <button class="btn btn-primary w-100" type="submit">
                Войти
            </button>
        </div>
    </div>
</form>
{% endblock %}
