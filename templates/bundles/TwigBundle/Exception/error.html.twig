{% extends 'base.html.twig' %}

{% block title %}Ошибка {{ status_code }} / StudyOn{% endblock %}

{% block navbar %}{% endblock %}

{% block body %}
    <div class="d-flex flex-column justify-content-center align-items-center text-center">
        <div class="mb-4">
            <div class="display-1 fw-bold text-danger">{{ status_code }}</div>
            <h2 class="mb-3">Произошла ошибка</h2>
            <p class="text-body-secondary mb-0">
                Что-то пошло не так. Попробуйте обновить страницу позже
            </p>
        </div>

        <div class="d-flex gap-2">
            <a href="{{ path('app_course_index') }}" class="btn btn-primary">
                На главную
            </a>
            <a href="javascript:history.back()" class="btn btn-outline-secondary">
                Назад
            </a>
        </div>
    </div>
{% endblock %}
