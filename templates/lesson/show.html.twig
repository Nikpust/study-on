{% extends 'base.html.twig' %}

{% block title %}{{ lesson.title }} / {{ course.title }} / StudyOn{% endblock %}

{% block body %}
    <h1>{{ lesson.title }}</h1>
    <p>
        Курс:
        <a href="{{ path('app_course_show', {'id': course.id}) }}">
            {{ course.title }}
        </a>
