{% extends 'base.html.twig' %}

{% block title %}Редактирование: {{ course.title }} / StudyOn{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center">
        <h1>Редактировать курс</h1>

        <div class="d-flex gap-2">
            <button type="submit" form="course-form" class="btn btn-success">
                Сохранить
            </button>

            <a href="{{ path('app_course_show', {'id': course.id}) }}" class="btn btn-danger">
                Отмена
            </a>
        </div>
    </div>

    {{ include('course/_form.html.twig') }}
{% endblock %}
