{% extends 'base.html.twig' %}

{% block title %}Курсы / StudyOn{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center">
        <h1>Курсы</h1>
        <a href="{{ path('app_course_new') }}" class="btn btn-primary">
            Создать новый курс
        </a>
    </div>

    {% if courses is not empty %}
        <div class="courses-grid">
            {% for course in courses %}
                <div class="card rounded-3">
                    <div class="card-body">
                        <h4 class="card-title">
                            <a href="{{ path('app_course_show', {'id': course.id}) }}" class="text-decoration-none">
                                {{ course.title }}
                            </a>
                        </h4>

                        {% if course.description %}
                            <p class="card-text mb-0">{{ course.description }}</p>
                        {% else %}
                            <p class="text-body-secondary mb-0">Описание отсутствует</p>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="alert alert-secondary">
            Курсы не найдены
        </div>
    {% endif %}
{% endblock %}
