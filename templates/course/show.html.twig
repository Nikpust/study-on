{% extends 'base.html.twig' %}

{% block title %}{{ course.title }} / Курсы / StudyOn{% endblock %}

{% block body %}
    <a href="{{ path('app_course_index') }}">Назад</a>

    <h1>{{ course.title }}</h1>
    {% if course.description %}
        <p>{{ course.description }}</p>
    {% endif %}

    <h2>Уроки:</h2>
    <ol>
        {% for lesson in lessons %}
            <li><a href="{{ path('app_lesson_show', {'id': lesson.id}) }}">{{ lesson.title }}</a></li>
        {% else %}
            <p>Уроки не найдены</p>
        {% endfor %}
    </ol>
    
    <hr>

    <a href="{{ path('app_course_edit', {'id': course.id}) }}">Редактировать курс</a>
    <a href="{{ path('app_lesson_new', {'course_id': course.id}) }}">Добавить урок</a>

    {{ include('course/_delete_form.html.twig') }}
{% endblock %}
