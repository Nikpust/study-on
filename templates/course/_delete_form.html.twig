{% if is_granted('ROLE_SUPER_ADMIN') %}
    <form id="delete-course-form" method="post" action="{{ path('app_course_delete', {'id': course.id}) }}" onsubmit="return confirm('Вы уверены, что хотите удалить курс?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ course.id) }}">
    </form>
{% endif %}
