{% extends 'base.html.twig' %}

{% block title %}Профиль / StudyOn{% endblock %}

{% block body %}
    {% if error %}
        <div class="d-flex flex-column align-items-center w-100">
            <div class="alert alert-danger d-flex align-items-center w-50" role="alert">
                <div class="w-100">
                    {{ error }}
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    {% endif %}

    <div class="w-100 m-0 p-0">
        <div class="card rounded-4">
            <div class="card-body p-4 p-md-5">
                <h1 class="h3">Профиль</h1>
                <p class="text-secondary">Здесь представлена информация о вашем аккаунте</p>

                <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                    <span class="text-secondary">Email</span>
                    <span class="fw-semibold">{{ app.user.email }}</span>
                </div>

                <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                    <span class="text-secondary">Роль</span>
                    <span class="fw-semibold">
                        {% if is_granted('ROLE_SUPER_ADMIN') %}
                            Администратор
                        {% else %}
                            Пользователь
                        {% endif %}
                    </span>
                </div>

                <div class="d-flex justify-content-between align-items-center py-3">
                    <span class="text-secondary">Баланс</span>
                    <span class="fw-bold fs-5 text-primary">
                        {% if balance is not null %}
                            {{ balance }} ₽
                        {% else %}
                            <span class="text-danger">-</span>
                        {% endif %}
                    </span>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
